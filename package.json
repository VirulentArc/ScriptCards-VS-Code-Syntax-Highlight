{
  "name": "scriptcards-vscode-syntax-highlight",
  "displayName": "ScriptCards VS Code Syntax Highlight",
  "description": "Syntax highlighting for Roll20 ScriptCards files in VS Code, tuned for dark themes.",
  "version": "1.0.1",
  "publisher": "Tim Beasley",
  "author": "Tim Beasley",
  "license": "MIT",
  "engines": {
    "vscode": "^1.67.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "scriptcards",
    "roll20",
    "vscode",
    "syntax",
    "highlighting",
    "dnd",
    "api"
  ],
  "contributes": {
    "languages": [
      {
        "id": "roll20-scriptcards",
        "aliases": [
          "ScriptCards",
          "Roll20 ScriptCards",
          "ScriptCards VS Code Syntax Highlight"
        ],
        "extensions": [
          ".scard",
          ".scard.txt",
          ".scriptcard",
          ".scriptcards"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "roll20-scriptcards",
        "scopeName": "text.roll20-scriptcards",
        "path": "./syntaxes/scriptcards.tmLanguage.json"
      }
    ],
    "configurationDefaults": {
      "files.associations": {
        "*.scard": "roll20-scriptcards",
        "*.scard.txt": "roll20-scriptcards",
        "*.scriptcard": "roll20-scriptcards",
        "*.scriptcards": "roll20-scriptcards"
      },
      "editor.tokenColorCustomizations": {
        "textMateRules": [
          {
            "scope": "support.variable.property.loopname.scriptcards",
            "settings": {
              "foreground": "#00E5FF"
            }
          },
          {
            "scope": "variable.other.readwrite.loopname.scriptcards, variable.other.loop.name.scriptcards, entity.name.type.loop.scriptcards",
            "settings": {
              "foreground": "#00E5FF"
            }
          }
        ]
      }
    }
  }
}
