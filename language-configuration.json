        ]
    ],
    "onEnterRules": [
        {
            "beforeText": "--(@|:|\\\\^|~|[cC]|[dD]|[hH]|[pP]|[rR]|[wW]|[zZ]|\\\\\\\\|\\\\*|[lL]|!|#|\\\\>|=|&|[sS]|[vV]|[xX]|a|A|\\\\+|%)",
            "action": {
                "indent": "none",
                "appendText": "--"
            }
        },
        {
            "beforeText": "^\\\\s*--%(.+)\\\\|.*$",
            "action": {
                "indent": "indent",
                "appendText": "--\\n--%|"
            }
        },
        {
            "beforeText": "^--$",
            "action": {
                "indent": "none",
                "removeText": 2
            }
        },
        {
            "beforeText": "^--\\\\?.+(?=\\\\|\\\\[$)",
            "action": {
                "indent": "indent",
                "appendText": "--\\n--]|"
            }
        }
    ]
}